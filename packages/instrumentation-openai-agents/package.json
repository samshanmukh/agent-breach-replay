{
  "name": "@agent-breach/instrumentation-openai-agents",
  "version": "0.1.0",
  "description": "Local OpenAI Agents SDK instrumentation with OpenInference-compatible span semantics for Agent Breach Replay.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai-agents", "openai-agents", "tracing", "instrumentation", "openinference"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agent-breach/trace-schema": "0.1.0"
  },
  "peerDependencies": {
    "@openai/agents": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
